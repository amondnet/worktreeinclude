{
  "name": "worktreeinclude",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "bun@1.3.13",
  "description": "Copy gitignored files matching .worktreeinclude patterns into a git worktree",
  "author": "Minsu Lee <minsu.lee@dietfriends.kr>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amondnet/worktreeinclude.git"
  },
  "keywords": [
    "git",
    "worktree",
    "gitignore",
    "bun",
    "claude-code"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "worktreeinclude": "./src/cli.ts"
  },
  "files": [
    "LICENSE",
    "README.md",
    "src"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "start": "bun run src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "devDependencies": {
    "@pleaseai/eslint-config": "^0.0.1",
    "@types/bun": "latest",
    "eslint": "^9.10.0",
    "jiti": "^2.7.0",
    "typescript": "^5.6.0"
  }
}
